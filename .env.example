# =============================================================================
# panorama-mail environment configuration
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Proton Bridge credentials
# IMPORTANT: PROTON_PASSWORD is the Bridge-specific password shown in the
# "Configure your email client" screen — NOT your Proton account password.
# PROTON_USERNAME is the full email address (e.g. louiscasinelli@pm.me).
# It is also used as the From: address on outbound messages.
# -----------------------------------------------------------------------------
PROTON_USERNAME=louiscasinelli@pm.me
PROTON_PASSWORD=<bridge-password-from-proton-bridge-ui>

# -----------------------------------------------------------------------------
# IMAP — Proton Bridge defaults
# Bridge advertises TLS upgrade capability but accepts plain connections on localhost.
# If IMAP authentication fails, check Bridge is running and unlocked.
# -----------------------------------------------------------------------------
IMAP_HOST=127.0.0.1
IMAP_PORT=1143

# Mailbox to read from. INBOX is the default; Bridge also exposes
# [Proton Mail]/Sent, [Proton Mail]/Drafts, etc.
MAILBOX=INBOX

# -----------------------------------------------------------------------------
# SMTP — Proton Bridge defaults
# Current implementation uses plain mode (no TLS negotiation on connect).
# Bridge on localhost accepts plain AUTH over the unencrypted local socket.
# If sends fail with a TLS or auth error, see src/mail/smtp.rs for the
# transport builder — switch to relay() with cert verification disabled.
# -----------------------------------------------------------------------------
SMTP_HOST=127.0.0.1
SMTP_PORT=1025

# -----------------------------------------------------------------------------
# HTTP server (panorama-mail serve)
# Port for the Axum REST API.
# -----------------------------------------------------------------------------
HTTP_PORT=8420
